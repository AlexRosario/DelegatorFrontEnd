# Copy to .env (or .env.local) and fill in. Vite only exposes VITE_-prefixed vars.

# Backend base URL. Local dev can omit this (code defaults to http://localhost:8080).
# Set to your deployed backend when going live, e.g. https://api.yourdomain.com
VITE_API_URL=http://localhost:8080

# Third-party keys used directly by the frontend
VITE_GOOGLE_API_KEY=
VITE_API_KEY=
